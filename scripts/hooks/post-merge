#!/bin/bash
cd "$(git rev-parse --show-toplevel)"

HASH=$(git rev-parse --short HEAD)
ARCHIVE=$(ls build/web/marbleelimination.tar.gz 2>/dev/null | head -1)
#echo "archive is $ARCHIVE"

if [ -z "$ARCHIVE" ]; then
    echo "post-merge: no marbleelimination.tar.gz found, skipping cache busting"
    exit 0
fi

BASE=$(basename "${ARCHIVE%.tar.gz}")
NEW_ARCHIVE="build/web/${BASE}.${HASH}.tar.gz"

ln -s "$(basename $ARCHIVE)" "$NEW_ARCHIVE"
echo "s/$(basename $ARCHIVE)/$(basename $NEW_ARCHIVE)/g"
sed -i "s/$(basename $ARCHIVE)/$(basename $NEW_ARCHIVE)/g" build/web/index.html

echo "post-merge: renamed $(basename $ARCHIVE) → $(basename $NEW_ARCHIVE)"

# Remove old versioned archives, keep only the new one
find build/web -maxdepth 1 -name "*.tar.gz" ! -name "${BASE}.${HASH}.tar.gz" ! -name "${BASE}.tar.gz" -delete
