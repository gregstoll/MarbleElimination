#!/bin/bash
cd "$(git rev-parse --show-toplevel)"

HASH=$(git rev-parse --short HEAD)
ARCHIVE=$(ls *.tar.gz 2>/dev/null | head -1)

if [ -z "$ARCHIVE" ]; then
    echo "post-merge: no .tar.gz found, skipping cache busting"
    exit 0
fi

BASE="${ARCHIVE%.tar.gz}"
NEW_ARCHIVE="${BASE}.${HASH}.tar.gz"

mv "$ARCHIVE" "$NEW_ARCHIVE"
sed -i "s/${ARCHIVE}/${NEW_ARCHIVE}/g" index.html

echo "post-merge: renamed $ARCHIVE → $NEW_ARCHIVE"

# Remove old versioned archives, keep only the new one
find . -maxdepth 1 -name "*.tar.gz" ! -name "$NEW_ARCHIVE" -delete
